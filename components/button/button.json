{
  "name": "Button",
  "description": "Triggers an action. Use primary for the dominant action, secondary for supporting ones, destructive for irreversible operations.",
  "props": {
    "type": {
      "type": "variant",
      "values": [
        "primary"
      ],
      "default": "primary"
    },
    "size": {
      "type": "variant",
      "values": [
        "medium",
        "small"
      ],
      "default": "medium"
    }
  },
  "slots": {
    "icon": {
      "layer": "Icon",
      "type": "instance"
    },
    "label": {
      "layer": "Label",
      "type": "text"
    }
  },
  "tokens": {
    "base": {
      "radius": "borderRadius/md",
      "padding y": "spacing/2",
      "padding x": "spacing/4",
      "gap": "spacing/1",
      "fill": "semantic/interactive/default",
      "width": "iconSize/xl",
      "height": "iconSize/xl",
      "icon color": "semantic/text/inverse",
      "text color": "semantic/text/inverse",
      "font size": "typography/fontSize/md",
      "line height": "typography/lineHeight/normal",
      "font weight": "typography/fontWeight/regular"
    },
    "sizes": {
      "small": {
        "padding y": "spacing/1",
        "padding x": "spacing/3",
        "width": "iconSize/md",
        "height": "iconSize/md",
        "font size": "typography/fontSize/base"
      }
    },
    "states": {
      "hover": {
        "fill": "semantic/interactive/hover"
      },
      "focus": {
        "fill": "semantic/interactive/focus"
      },
      "disabled": {
        "fill": "semantic/interactive/disabled-bg",
        "icon color": "semantic/interactive/disabled",
        "text color": "semantic/interactive/disabled"
      }
    }
  },
  "states": [
    "default",
    "hover",
    "focus",
    "disabled"
  ]
}