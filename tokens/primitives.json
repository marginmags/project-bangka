{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "color": {
    "$description": "Primitive color values. Never used directly in components — go through semantic tokens.",
    "gray": {
      "0":   { "$value": "#ffffff", "$type": "color" },
      "50":  { "$value": "#f9fafb", "$type": "color" },
      "100": { "$value": "#f3f4f6", "$type": "color" },
      "200": { "$value": "#e5e7eb", "$type": "color" },
      "300": { "$value": "#d1d5db", "$type": "color" },
      "400": { "$value": "#9ca3af", "$type": "color" },
      "500": { "$value": "#6b7280", "$type": "color" },
      "600": { "$value": "#4b5563", "$type": "color" },
      "700": { "$value": "#374151", "$type": "color" },
      "800": { "$value": "#1f2937", "$type": "color" },
      "900": { "$value": "#111827", "$type": "color" }
    },
    "teal": {
      "$description": "Brand teal — interactive elements, brand identity.",
      "50":  { "$value": "#f0fdfa", "$type": "color" },
      "100": { "$value": "#ccfbf1", "$type": "color" },
      "200": { "$value": "#99f6e4", "$type": "color" },
      "300": { "$value": "#5eead4", "$type": "color" },
      "400": { "$value": "#2dd4bf", "$type": "color" },
      "500": { "$value": "#14b8a6", "$type": "color" },
      "600": { "$value": "#0d9488", "$type": "color" },
      "700": { "$value": "#0f766e", "$type": "color" },
      "800": { "$value": "#115e59", "$type": "color" },
      "900": { "$value": "#134e4a", "$type": "color" }
    },
    "blue": {
      "$description": "System blue — info feedback states.",
      "50":  { "$value": "#eff6ff", "$type": "color" },
      "100": { "$value": "#dbeafe", "$type": "color" },
      "200": { "$value": "#bfdbfe", "$type": "color" },
      "300": { "$value": "#93c5fd", "$type": "color" },
      "400": { "$value": "#60a5fa", "$type": "color" },
      "500": { "$value": "#3b82f6", "$type": "color" },
      "600": { "$value": "#2563eb", "$type": "color" },
      "700": { "$value": "#1d4ed8", "$type": "color" },
      "800": { "$value": "#1e40af", "$type": "color" },
      "900": { "$value": "#1e3a8a", "$type": "color" }
    },
    "green": {
      "50":  { "$value": "#f0fdf4", "$type": "color" },
      "100": { "$value": "#dcfce7", "$type": "color" },
      "200": { "$value": "#bbf7d0", "$type": "color" },
      "300": { "$value": "#86efac", "$type": "color" },
      "400": { "$value": "#4ade80", "$type": "color" },
      "500": { "$value": "#22c55e", "$type": "color" },
      "600": { "$value": "#16a34a", "$type": "color" },
      "700": { "$value": "#15803d", "$type": "color" },
      "800": { "$value": "#166534", "$type": "color" },
      "900": { "$value": "#14532d", "$type": "color" }
    },
    "amber": {
      "50":  { "$value": "#fffbeb", "$type": "color" },
      "100": { "$value": "#fef3c7", "$type": "color" },
      "200": { "$value": "#fde68a", "$type": "color" },
      "300": { "$value": "#fcd34d", "$type": "color" },
      "400": { "$value": "#fbbf24", "$type": "color" },
      "500": { "$value": "#f59e0b", "$type": "color" },
      "600": { "$value": "#d97706", "$type": "color" },
      "700": { "$value": "#b45309", "$type": "color" },
      "800": { "$value": "#92400e", "$type": "color" },
      "900": { "$value": "#78350f", "$type": "color" }
    },
    "red": {
      "50":  { "$value": "#fef2f2", "$type": "color" },
      "100": { "$value": "#fee2e2", "$type": "color" },
      "200": { "$value": "#fecaca", "$type": "color" },
      "300": { "$value": "#fca5a5", "$type": "color" },
      "400": { "$value": "#f87171", "$type": "color" },
      "500": { "$value": "#ef4444", "$type": "color" },
      "600": { "$value": "#dc2626", "$type": "color" },
      "700": { "$value": "#b91c1c", "$type": "color" },
      "800": { "$value": "#991b1b", "$type": "color" },
      "900": { "$value": "#7f1d1d", "$type": "color" }
    }
  },
  "spacing": {
    "$description": "Base unit: 4px. All values are multiples of 4.",
    "0":  { "$value": "0px",  "$type": "dimension" },
    "1":  { "$value": "4px",  "$type": "dimension", "$description": "Micro — icon padding, tight gaps" },
    "2":  { "$value": "8px",  "$type": "dimension", "$description": "Small — inline gaps, compact padding" },
    "3":  { "$value": "12px", "$type": "dimension", "$description": "Default component padding" },
    "4":  { "$value": "16px", "$type": "dimension", "$description": "Standard — most component padding" },
    "5":  { "$value": "20px", "$type": "dimension", "$description": "Comfortable — section padding" },
    "6":  { "$value": "24px", "$type": "dimension", "$description": "Large — panel padding, section gaps" },
    "8":  { "$value": "32px", "$type": "dimension", "$description": "XL — major section separation" },
    "10": { "$value": "40px", "$type": "dimension", "$description": "2XL — page-level spacing" },
    "12": { "$value": "48px", "$type": "dimension", "$description": "3XL — hero spacing, empty states" }
  },
  "borderRadius": {
    "sm":   { "$value": "4px",    "$type": "dimension", "$description": "Inputs, small elements" },
    "md":   { "$value": "6px",    "$type": "dimension", "$description": "Buttons, cards — default" },
    "lg":   { "$value": "8px",    "$type": "dimension", "$description": "Panels, modals" },
    "xl":   { "$value": "12px",   "$type": "dimension", "$description": "Large cards, overlays" },
    "full": { "$value": "9999px", "$type": "dimension", "$description": "Pills, badges, avatars" }
  },
  "shadow": {
    "sm": { "$value": "0 1px 2px rgba(0,0,0,0.05)",                                            "$type": "shadow", "$description": "Subtle lift" },
    "md": { "$value": "0 4px 6px -1px rgba(0,0,0,0.07), 0 2px 4px -1px rgba(0,0,0,0.04)",     "$type": "shadow", "$description": "Cards, dropdowns" },
    "lg": { "$value": "0 10px 15px -3px rgba(0,0,0,0.08), 0 4px 6px -2px rgba(0,0,0,0.04)",   "$type": "shadow", "$description": "Modals, popovers" }
  },
  "iconSize": {
    "xs": { "$value": "12px", "$type": "dimension", "$description": "Inline with text-xs" },
    "sm": { "$value": "14px", "$type": "dimension", "$description": "Inline with text-sm/base — most common" },
    "md": { "$value": "16px", "$type": "dimension", "$description": "Standalone icons in controls" },
    "lg": { "$value": "20px", "$type": "dimension", "$description": "Section icons, empty states" },
    "xl": { "$value": "24px", "$type": "dimension", "$description": "Feature icons, illustrations" }
  }
}
